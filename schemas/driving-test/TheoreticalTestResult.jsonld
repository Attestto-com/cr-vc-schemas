{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "TheoreticalTestResult"],
  "credentialSubject": {
    "id": "did:example:titular",
    "theoreticalTest": {
      "type": "TheoreticalTestResultValue",
      "status": "approved | failed",
      "score": "integer (0-100)",
      "passingScore": "integer",
      "category": "string (B, C, D, etc.)",
      "testDate": "dateTime",
      "expiresAt": "dateTime (resultado valido por 90 dias)",
      "modality": "online | in-person",
      "testCenterDID": "did:example:proveedor",
      "testCenterName": "string",
      "examVersionHash": "string (SHA-256 del banco de preguntas utilizado)",
      "totalQuestions": "integer",
      "correctAnswers": "integer",
      "durationMinutes": "integer",
      "language": "es | en",
      "proctoring": {
        "method": "remote-biometric | in-person-supervised",
        "telemetryHash": "string (hash WORM de la telemetria de la sesion)",
        "sessionId": "string (UUID)",
        "anomaliesDetected": "integer",
        "livenessVerified": "boolean",
        "identityVerified": "boolean"
      },
      "attemptNumber": "integer"
    }
  },
  "issuer": "did:web:dgev.go.cr",
  "issuanceDate": "dateTime",
  "credentialStatus": {
    "id": "https://status.attestto.org/cr/credentials/status/2",
    "type": "StatusList2021Entry",
    "statusPurpose": "revocation",
    "statusListIndex": "integer",
    "statusListCredential": "https://status.attestto.org/cr/credentials/status-list/1"
  }
}
