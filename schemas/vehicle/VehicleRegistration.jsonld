{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "VehicleRegistration"],
  "credentialSubject": {
    "id": "did:example:vehiculo",
    "vehicle": {
      "type": "VehicleRegistrationValue",
      "plate": "string (ABC-123)",
      "vin": "string (Vehicle Identification Number)",
      "ownerDID": "did:example:propietario",
      "registrationDate": "date",
      "vehicleType": "string (sedan, SUV, motocicleta, camion, bus)",
      "make": "string (Toyota, Hyundai, etc.)",
      "model": "string",
      "year": "integer",
      "color": "string",
      "engineNumber": "string",
      "seatingCapacity": "integer"
    }
  },
  "issuer": "did:web:registronacional.go.cr",
  "issuanceDate": "dateTime"
}
