{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.attestto.org/cr/driving/v1/MedicalFitnessCredential.schema.json",
  "title": "Dictamen Medico de Aptitud para Conducir",
  "description": "Resultado funcional (apto/no apto) del examen medico. NUNCA incluye diagnostico clinico — solo el resultado funcional y las categorias autorizadas.",
  "type": "object",
  "required": ["credentialSubject"],
  "properties": {
    "credentialSubject": {
      "type": "object",
      "required": ["id", "fitness"],
      "properties": {
        "id": { "type": "string", "pattern": "^did:" },
        "fitness": {
          "type": "object",
          "required": ["status", "categories", "issuedDate", "expiresAt", "physicianDID", "clinicDID"],
          "properties": {
            "status": { "type": "string", "enum": ["fit", "unfit", "conditional"] },
            "categories": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Categorias de licencia para las que el conductor esta apto"
            },
            "issuedDate": { "type": "string", "format": "date" },
            "expiresAt": { "type": "string", "format": "date-time" },
            "physicianDID": { "type": "string", "pattern": "^did:" },
            "physicianName": { "type": "string" },
            "physicianLicense": { "type": "string", "description": "Numero de colegiatura del Colegio de Medicos" },
            "clinicDID": { "type": "string", "pattern": "^did:" },
            "clinicName": { "type": "string" },
            "restrictions": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Restricciones funcionales (lentes, protesis, solo diurno)"
            }
          }
        }
      }
    }
  }
}
