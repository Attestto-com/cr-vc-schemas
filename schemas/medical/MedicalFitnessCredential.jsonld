{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "MedicalFitnessCredential"],
  "credentialSubject": {
    "id": "did:example:titular",
    "fitness": {
      "type": "MedicalFitnessValue",
      "status": "fit | unfit | conditional",
      "categories": ["B", "C"],
      "issuedDate": "date",
      "expiresAt": "dateTime",
      "physicianDID": "did:example:medico",
      "physicianName": "string",
      "physicianLicense": "string (numero de colegiatura)",
      "clinicDID": "did:example:consultorio",
      "clinicName": "string",
      "restrictions": ["string (uso de lentes, protesis auditiva, etc.)"]
    }
  },
  "issuer": "did:example:consultorio",
  "issuanceDate": "dateTime",
  "credentialStatus": {
    "id": "https://status.attestto.org/cr/credentials/status/3",
    "type": "StatusList2021Entry",
    "statusPurpose": "revocation",
    "statusListIndex": "integer",
    "statusListCredential": "https://status.attestto.org/cr/credentials/status-list/1"
  }
}
