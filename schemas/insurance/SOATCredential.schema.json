{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.attestto.org/cr/driving/v1/SOATCredential.schema.json",
  "title": "Seguro Obligatorio Automotor (SOAT)",
  "description": "Credencial de seguro obligatorio vehicular emitida por el INS.",
  "type": "object",
  "required": ["credentialSubject"],
  "properties": {
    "credentialSubject": {
      "type": "object",
      "required": ["id", "insurance"],
      "properties": {
        "id": { "type": "string", "pattern": "^did:" },
        "insurance": {
          "type": "object",
          "required": ["policyNumber", "coverageType", "issueDate", "expiresAt", "insurerDID"],
          "properties": {
            "policyNumber": { "type": "string" },
            "coverageType": { "type": "string", "enum": ["SOAT", "voluntario", "RC_ampliada"] },
            "issueDate": { "type": "string", "format": "date" },
            "expiresAt": { "type": "string", "format": "date" },
            "insurer": { "type": "string" },
            "insurerDID": { "type": "string", "pattern": "^did:" },
            "premium": { "type": "number" },
            "currency": { "type": "string", "default": "CRC" }
          }
        }
      }
    }
  }
}
