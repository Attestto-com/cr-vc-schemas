{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "SOATCredential"],
  "credentialSubject": {
    "id": "did:example:vehiculo",
    "insurance": {
      "type": "SOATInsuranceValue",
      "policyNumber": "string",
      "coverageType": "SOAT | voluntario | RC_ampliada",
      "issueDate": "date",
      "expiresAt": "date",
      "insurer": "Instituto Nacional de Seguros",
      "insurerDID": "did:web:ins.go.cr",
      "premium": "decimal",
      "currency": "CRC"
    }
  },
  "issuer": "did:web:ins.go.cr",
  "issuanceDate": "dateTime"
}
