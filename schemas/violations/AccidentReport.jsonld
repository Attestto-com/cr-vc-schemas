{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "AccidentReport"],
  "credentialSubject": {
    "id": "did:web:reporte.attestto.id",
    "accident": {
      "type": "AccidentReportValue",
      "timestamp": "dateTime",
      "location": "string",
      "latitude": "decimal",
      "longitude": "decimal",
      "severity": "minor | moderate | severe | fatal",
      "parties": [
        {
          "conductorDID": "did:web:conductor-1.attestto.id",
          "vehicleDID": "did:web:vehiculo-1.attestto.id",
          "insurancePolicyRef": "string",
          "role": "driver | passenger | pedestrian"
        }
      ],
      "reportNumber": "string (numero de parte oficial)",
      "officerDID": "did:web:oficial.attestto.id",
      "description": "string"
    }
  },
  "issuer": "did:web:cosevi.attestto.id",
  "issuanceDate": "dateTime"
}
