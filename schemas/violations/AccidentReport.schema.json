{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.attestto.org/cr/driving/v1/AccidentReport.schema.json",
  "title": "Parte de Accidente de Transito",
  "description": "Reporte de accidente vinculado a los DIDs de conductores, vehiculos y polizas involucradas.",
  "type": "object",
  "required": ["credentialSubject"],
  "properties": {
    "credentialSubject": {
      "type": "object",
      "required": ["id", "accident"],
      "properties": {
        "id": { "type": "string" },
        "accident": {
          "type": "object",
          "required": ["timestamp", "severity", "parties", "reportNumber", "officerDID"],
          "properties": {
            "timestamp": { "type": "string", "format": "date-time" },
            "location": { "type": "string" },
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "severity": { "type": "string", "enum": ["minor", "moderate", "severe", "fatal"] },
            "parties": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["conductorDID", "role"],
                "properties": {
                  "conductorDID": { "type": "string", "pattern": "^did:" },
                  "vehicleDID": { "type": "string", "pattern": "^did:" },
                  "insurancePolicyRef": { "type": "string" },
                  "role": { "type": "string", "enum": ["driver", "passenger", "pedestrian"] }
                }
              }
            },
            "reportNumber": { "type": "string" },
            "officerDID": { "type": "string", "pattern": "^did:" },
            "description": { "type": "string" }
          }
        }
      }
    }
  }
}
