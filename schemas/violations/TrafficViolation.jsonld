{
  "@context": [
    "https://www.w3.org/2018/credentials/v1",
    "https://schemas.attestto.org/cr/driving/v1"
  ],
  "type": ["VerifiableCredential", "TrafficViolation"],
  "credentialSubject": {
    "id": "did:example:titular",
    "violation": {
      "type": "TrafficViolationValue",
      "violationType": "string (exceso_velocidad, semaforo_rojo, conduccion_temeraria, etc.)",
      "points": "integer (puntos deducidos)",
      "fineAmount": "decimal",
      "currency": "CRC",
      "location": "string (descripcion de ubicacion)",
      "latitude": "decimal",
      "longitude": "decimal",
      "timestamp": "dateTime",
      "officerDID": "did:example:oficial",
      "vehicleDID": "did:example:vehiculo",
      "articleNumber": "string (articulo de la Ley de Transito)",
      "description": "string"
    }
  },
  "issuer": "did:web:cosevi.go.cr",
  "issuanceDate": "dateTime"
}
